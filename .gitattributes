# Normalise line endings
* text=auto eol=lf
*.sh text eol=lf
*.bat text eol=crlf

# ───────── Git LFS recommendations ─────────
# If you choose to commit the larger binary/data artifacts, track them with
# Git LFS (install: https://git-lfs.com). Uncomment to enable:
#
# *.pkl   filter=lfs diff=lfs merge=lfs -text
# *.xlsx  filter=lfs diff=lfs merge=lfs -text
# *.pptx  filter=lfs diff=lfs merge=lfs -text
# *.pdf   filter=lfs diff=lfs merge=lfs -text
# *.cif   filter=lfs diff=lfs merge=lfs -text
# *.pdb   filter=lfs diff=lfs merge=lfs -text
#
# The single largest input (data/external/Exclusion_List.csv, ~32 MB) is the
# best candidate for LFS or an external data host. See data/external/README.md.

# Treat structure/data formats as text for diffing where small
*.fasta text
*.pdb   text
*.smi   text
*.in    text
*.gjf   text
